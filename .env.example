# ===========================================
# FastAPI Enterprise Boilerplate - Environment Configuration
# ===========================================

# Application
APP_NAME="FastAPI Enterprise Boilerplate"
APP_VERSION=1.3.0
ENVIRONMENT=development
DEBUG=true
DEFAULT_LOCALE=en

# Database (PostgreSQL)
# DEVELOPMENT: Use 'boilerplate' user (owner) - RLS bypassed for admin tasks
DATABASE_URL=postgresql+asyncpg://boilerplate:boilerplate@localhost:5432/boilerplate
# PRODUCTION: Use 'app_user' (non-owner) - RLS enforcement active for security
# DATABASE_URL=postgresql+asyncpg://app_user:app_password@localhost:5432/boilerplate
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
# ⚠️ CHANGE THIS IN PRODUCTION! Minimum 32 characters.
JWT_SECRET_KEY=change-this-in-production-with-strong-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# MFA (Multi-Factor Authentication)
MFA_ENABLED=true
MFA_ISSUER_NAME="FastAPI Enterprise Boilerplate"

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Feature Flags
FEATURE_FLAGS_ENABLED=true

# Observability (OpenTelemetry)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO
LOG_FORMAT=console

# ===========================================
# CORS (Cross-Origin Resource Sharing)
# ===========================================
# DEVELOPMENT: Allow localhost origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
# PRODUCTION: Replace with your actual domains
# CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com","https://app.yourdomain.com"]

# ===========================================
# Storage (Pluggable Architecture)
# ===========================================
# Backend: auto (default), local, s3, minio
# "auto" will use S3 if configured, otherwise falls back to local
STORAGE_BACKEND=auto
STORAGE_LOCAL_PATH=./storage

# AWS S3 Configuration (optional)
# Leave empty to use local storage fallback
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# MinIO Configuration (S3-compatible, optional)
# Self-hosted alternative to AWS S3
MINIO_ENDPOINT=
MINIO_BUCKET=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=true

# ===========================================
# WebSocket & Real-time Features (Pluggable)
# ===========================================
# WebSocket (for real-time notifications)
# ===========================================
WEBSOCKET_ENABLED=true
WEBSOCKET_BACKEND=memory
WEBSOCKET_NOTIFICATIONS=true

# ===========================================
# Email Configuration
# ===========================================
# Backend: console (dev), smtp, sendgrid, aws_ses, mailgun
EMAIL_BACKEND=console
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME="FastAPI Enterprise"
EMAIL_SUPPORT=support@example.com

# SMTP Configuration (when EMAIL_BACKEND=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true

# SendGrid Configuration (when EMAIL_BACKEND=sendgrid)
SENDGRID_API_KEY=

# AWS SES Configuration (when EMAIL_BACKEND=aws_ses)
AWS_SES_REGION=us-east-1

# Mailgun Configuration (when EMAIL_BACKEND=mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ===========================================
# OAuth2/SSO Configuration (Optional)
# ===========================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# OAuth Redirect URI (must match in OAuth provider console)
OAUTH_REDIRECT_URI=http://localhost:3000/auth/oauth/callback

# ===========================================
# Search Configuration (Optional)
# ===========================================
# Search backend: postgres (default), elasticsearch
SEARCH_BACKEND=postgres

# Elasticsearch Configuration (when SEARCH_BACKEND=elasticsearch)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
