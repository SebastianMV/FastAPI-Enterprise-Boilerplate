# ===========================================
# FastAPI Enterprise Boilerplate - Environment Configuration
# ===========================================

# Application
APP_NAME="FastAPI Enterprise Boilerplate"
APP_VERSION=0.9.0
ENVIRONMENT=development
DEBUG=true
FRONTEND_URL=http://localhost:3000
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,es,pt
CSRF_ENABLED=true

# Database (PostgreSQL)
# DEVELOPMENT: Use 'boilerplate' user (owner) - RLS bypassed for admin tasks
DATABASE_URL=postgresql+asyncpg://boilerplate:boilerplate@localhost:5432/boilerplate
# PRODUCTION: Use 'app_user' (non-owner) - RLS enforcement active for security
# DATABASE_URL=postgresql+asyncpg://app_user:app_password@localhost:5432/boilerplate
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
# Set to true in production if the database is on a remote host
DB_SSL_REQUIRED=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=devpassword
# WARNING: REDIS_PASSWORD must be set to a strong value in production/staging
REDIS_DB=0
# Composite URL (used by Docker services): redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}
# REDIS_URL=redis://:devpassword@localhost:6379/0

# ===========================================
# JWT Authentication
# ===========================================
# WARNING: CHANGE THIS IN PRODUCTION! Minimum 32 characters.
JWT_SECRET_KEY=change-this-in-production-with-strong-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# Encryption (at-rest secrets: MFA, OAuth tokens)
# ===========================================
# Separate key for encrypting secrets. If empty, derived from JWT_SECRET_KEY.
# Recommended: set a unique value in production.
ENCRYPTION_KEY=dev-only-encryption-key-change-in-production-min-32-chars

# ===========================================
# Cookie-based Authentication
# ===========================================
AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAMESITE=lax

# ===========================================
# Account Security
# ===========================================
ACCOUNT_LOCKOUT_ENABLED=true
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=30
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24

# ===========================================
# Cache Configuration
# ===========================================
CACHE_ENABLED=true
CACHE_PREFIX=fastapi_cache
CACHE_DEFAULT_TTL=300
CACHE_USER_TTL=60
CACHE_ROLE_TTL=300
CACHE_TENANT_TTL=600

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Observability (OpenTelemetry)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO
LOG_FORMAT=console

# ===========================================
# CORS (Cross-Origin Resource Sharing)
# ===========================================
# DEVELOPMENT: Allow localhost origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
# PRODUCTION: Replace with your actual domains
# CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com","https://app.yourdomain.com"]

# ===========================================
# Storage (Pluggable Architecture)
# ===========================================
# Backend: auto (default), local, s3, minio
# "auto" will use S3 if configured, otherwise falls back to local
STORAGE_BACKEND=auto
STORAGE_LOCAL_PATH=./storage

# AWS S3 Configuration (optional)
# Leave empty to use local storage fallback
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# MinIO Configuration (S3-compatible, optional)
# Self-hosted alternative to AWS S3
MINIO_ENDPOINT=
MINIO_BUCKET=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=true

# ===========================================
# WebSocket & Real-time Features
# ===========================================
# WebSocket for real-time notifications
WEBSOCKET_ENABLED=true
WEBSOCKET_NOTIFICATIONS=true

# ===========================================
# Email Configuration
# ===========================================
# Backend: console (dev), smtp, sendgrid, aws_ses, mailgun
EMAIL_BACKEND=console
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME="FastAPI Enterprise"
EMAIL_SUPPORT=support@example.com

# SMTP Configuration (when EMAIL_BACKEND=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true

# SendGrid Configuration (when EMAIL_BACKEND=sendgrid)
SENDGRID_API_KEY=

# AWS SES Configuration (when EMAIL_BACKEND=aws_ses)
SES_REGION=us-east-1

# Mailgun Configuration (when EMAIL_BACKEND=mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ===========================================
# OAuth2/SSO Configuration (Optional)
# ===========================================
# Google OAuth
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# GitHub OAuth
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Microsoft OAuth
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_TENANT_ID=common

# ===========================================
# Search Configuration (Optional)
# ===========================================
# Search backend: postgres (default)
SEARCH_BACKEND=postgres
SEARCH_PG_LANGUAGE=english
